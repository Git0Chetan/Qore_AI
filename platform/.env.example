# --- Supabase (create a project at https://supabase.com) ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Server-only. NEVER expose to the browser. Used by ATS + result write-backs.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Groq (AI: resume parsing + ATS scoring) ---
GROQ_API_KEY="your-groq-key"
GROQ_MODEL="llama-3.3-70b-versatile"

# --- LiveKit (assessment proctoring) ---
LIVEKIT_API_KEY="your-livekit-key"
LIVEKIT_API_SECRET="your-livekit-secret"
LIVEKIT_URL="wss://your-project.livekit.cloud"

# --- App URLs (used for handoff to the assessment + shareable job links) ---
NEXT_PUBLIC_APP_URL="http://localhost:3002"
NEXT_PUBLIC_QUIZ_URL="http://localhost:3001"
# agent-starter-react (LiveKit voice UI) — used for the AI interview round
NEXT_PUBLIC_AGENT_UI_URL="http://localhost:3000"

# --- Assessment handoff: binds the quiz session to one application (HMAC) ---
ASSESSMENT_SHARED_SECRET="a-long-random-string"

# --- Voice agent server-to-server secret (proctoring + interview results) ---
AGENT_SHARED_SECRET="another-long-random-string"

# --- AI interview: max attempts per candidate, and pass threshold (fallback) ---
INTERVIEW_MAX_ATTEMPTS="2"
INTERVIEW_PASS_SCORE="60"

# --- Learning module: YouTube Data API key (optional; falls back to curated content) ---
YOUTUBE_API_KEY=""

# --- Notifications (optional; email stub falls back to console logging) ---
RESEND_API_KEY=""
NOTIFY_FROM_EMAIL="recruiting@example.com"
